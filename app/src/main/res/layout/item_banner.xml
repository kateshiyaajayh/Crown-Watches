<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Video Player -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/bannerPlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:resize_mode="zoom"
            app:use_controller="false" />

        <!-- Background Image -->
        <ImageView
            android:id="@+id/bannerImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <!-- Overlay for text and button -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/textOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/offer_card_gradient"
            android:padding="20dp"
            android:visibility="visible">

            <!-- Text Content Grouped to be Centered Vertically -->
            <LinearLayout
                android:id="@+id/contentLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/sideWatchImage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/bannerTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Special Offer"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/bannerMainText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Get 30% Off on New Arrivals"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrabNow"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:paddingHorizontal="16dp"
                    android:text="Grab Now"
                    android:textAllCaps="false"
                    android:textColor="@color/purple_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/sideWatchImage"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:rotation="-15"
                android:src="@drawable/watch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </FrameLayout>
</androidx.cardview.widget.CardView>