<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Purple Header with Logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:background="@drawable/header_purple_shape"
            android:paddingStart="20dp"
            android:paddingTop="30dp">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/logo"
                android:contentDescription="@string/crown_watches_logo"
                android:scaleType="centerInside" />

        </LinearLayout>

        <!-- Main Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:paddingTop="30dp"
            android:paddingBottom="30dp">

            <!-- Title Section -->
            <TextView
                android:id="@+id/reset_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/reset_password_title"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:layout_marginBottom="15dp" />

            <!-- Purple Underline -->
            <View
                android:layout_width="130dp"
                android:layout_height="3dp"
                android:background="#6C63FF"
                android:layout_gravity="center"
                android:layout_marginBottom="30dp" />

            <!-- Mobile No Input with Send Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/mobile_input"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:hint="@string/reset_mobile_hint"
                    android:inputType="phone"
                    android:background="@android:color/transparent"
                    android:paddingStart="10dp"
                    android:textSize="16sp"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/send_button"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:text="@string/send_button"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/send_button_shape" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="20dp" />

            <!-- OTP Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/otp_input"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:hint="@string/reset_otp_hint"
                    android:inputType="number"
                    android:background="@android:color/transparent"
                    android:paddingStart="10dp"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/lock"
                    android:contentDescription="@string/otp_icon"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="20dp" />

            <!-- Remember Me Checkbox -->
            <CheckBox
                android:id="@+id/remember_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/remember_me"
                android:textSize="14sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="30dp" />

            <!-- Reset Button -->
            <Button
                android:id="@+id/reset_button"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:text="@string/reset_button"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/login_button_shape"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp" />

            <!-- Social Login Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="30dp">

                <ImageView
                    android:id="@+id/google_icon"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/google"
                    android:contentDescription="@string/google_login"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="30dp" />

                <ImageView
                    android:id="@+id/facebook_icon"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/facebook"
                    android:contentDescription="@string/facebook_login"
                    android:scaleType="centerInside"
                    android:layout_marginEnd="30dp" />

                <ImageView
                    android:id="@+id/apple_icon"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/apple"
                    android:contentDescription="@string/apple_login"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Register Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_account_part1"
                    android:textSize="14sp"
                    android:textColor="@android:color/black"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/register_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/register_link"
                    android:textSize="14sp"
                    android:textColor="#6C63FF"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
